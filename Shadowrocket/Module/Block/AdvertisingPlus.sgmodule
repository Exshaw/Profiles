#!name=Advertising+
#!desc=Block Advertising+ (May 07 2026)
#!url=https://raw.githubusercontent.com/Exshaw/Profiles/master/Shadowrocket/Module/Block/AdvertisingPlus.sgmodule
# @ddgksf2013: https://github.com/ddgksf2013/Rewrite/blob/master/AdBlock/BilibiliAdsLite.conf

[URL Rewrite]
^https?:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.app\.interface\.v1\.Search\/DefaultWords$ - reject

[Map Local]
^https?:\/\/api\.vc\.bilibili\.com\/search_svr\/v\d\/Search\/recommend_words data-type=text data="{}" header="application/json"
^https?:\/\/api\.vc\.bilibili\.com\/topic_svr\/v1\/topic_svr data-type=text data="{}" header="application/json"
^https?:\/\/api\.vc\.bilibili\.com\/dynamic_svr\/v1\/dynamic_svr\/mix_uplist data-type=text data="{}" header="application/json"
^https?:\/\/manga\.bilibili\.com\/twirp\/comic\.v\d\.Comic\/Flash data-type=text data="{}" header="application/json"
^https?:\/\/manga\.bilibili\.com\/twirp\/comic\.v\d\.Comic\/ListFlash data-type=text data="{}" header="application/json"
^https?:\/\/api\.live\.bilibili\.com\/xlive\/e-commerce-interface\/v1\/ecommerce-user\/get_shopping_info\? data-type=text data="{}" header="application/json"
^https:\/\/api\.bilibili\.com\/pgc\/activity\/deliver\/material\/receive\? header="content-type: application/json" data-type=text data="{"code":0,"data":{"closeType":"close_win","container":[],"showTime":""},"message":"success"}"

[Body Rewrite]
http-response-jq ^https:\/\/api\.bilibili\.com\/pgc\/view\/v2\/app\/season\? 'del(.data.payment)'

[Script]
BiliBili = type=http-request,engine=webview,pattern=^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/feed\/index\?,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/request.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,engine=webview,pattern=^https?:\/\/app\.bili(bili\.com|api\.net)\/x\/v2\/(splash\/(brand\/list|event\/list2|list|show)|feed\/index(\/story)?|search\/square),script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,engine=webview,pattern=^https?:\/\/api\.bilibili\.com\/x\/web-interface\/wbi\/index\/top\/feed\/rcmd\?,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,engine=webview,pattern=^https?:\/\/api\.bili(bili\.com|api\.net)\/pgc\/page\/(bangumi|cinema\/tab\?),script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,engine=webview,pattern=^https?:\/\/api\.live\.bilibili\.com\/xlive\/app-room\/v1\/index\/getInfoByRoom,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,binary-body-mode=true,max-size=262144,engine=webview,pattern=^https?:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.app\.(view|viewunite)\.v1\.View\/(View|TFInfo|RelatesFeed)$,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,binary-body-mode=true,engine=webview,pattern=^https?:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.app\.dynamic\.v2\.Dynamic\/Dyn(All|Video)$,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,binary-body-mode=true,engine=webview,pattern=^https?:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.app\.playurl\.v1\.PlayURL\/PlayView$,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,binary-body-mode=true,engine=webview,pattern=^https?:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.polymer\.app\.search\.v1\.Search\/SearchAll$,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,binary-body-mode=true,engine=webview,pattern=^https:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.community\.service\.dm\.v1\.DM\/(DmView|DmSegMobile),script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,binary-body-mode=true,engine=webview,pattern=^https:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.app\.interface\.v1\.Teenagers\/ModeStatus,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,binary-body-mode=true,engine=webview,pattern=^https:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.main\.community\.reply\.v1\.Reply\/MainList,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"
BiliBili = type=http-response,requires-body=true,binary-body-mode=true,engine=webview,pattern=^https:\/\/(grpc|app)\.bili(bili\.com|api\.net)\/bilibili\.pgc\.gateway\.player\.v2\.PlayURL\/PlayView$,script-path=https://github.com/BiliUniverse/ADBlock/releases/download/v0.6.24/response.bundle.js,argument=Splash=true&Feed.AD=true&Feed.Activity=true&Feed.Vertical=true&Feed.BlockUpLiveList=""&Feed.Story=true&Search.AD=true&Search.HotSearch=true&PGC.AD=true&Xlive.AD=true&Dynamic.HotTopics=true&Dynamic.MostVisited=false&Dynamic.MostVisitedLiveOnly=false&Dynamic.AdCard=true&View.AD=true&DM.Command=false&DM.Colorful=false&Reply.AD=true&LogLevel="WARN"

[MITM]
hostname = %APPEND% manga.bilibili.com,api.live.bilibili.com,api.vc.bilibili.com,app.bilibili.com,app.biliapi.net,api.bilibili.com,api.biliapi.net,grpc.biliapi.net
